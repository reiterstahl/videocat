POSTGRES_DB=videocat
POSTGRES_USER=videocat
POSTGRES_PASSWORD=replace-with-64-hex-random-characters
DATABASE_URL=postgresql://videocat:replace-with-64-hex-random-characters@postgres:5432/videocat
SERVER_PORT=4000
SERVER_BIND_ADDR=127.0.0.1
SERVER_PUBLISHED_PORT=4001
SERVER_HOST=0.0.0.0
WEB_ORIGIN=http://localhost:8081,http://localhost:5173
TRUST_PROXY=true
COOKIE_SECURE=true
WEB_BIND_ADDR=0.0.0.0
WEB_PUBLISHED_PORT=8081
# Generate strong values before running Docker in production, for example:
# openssl rand -hex 32
JWT_SECRET=replace-with-64-hex-random-characters
AGENT_TOKEN=replace-with-64-hex-random-characters
# Local Windows companion settings. Configure these from the tray app on Windows.
COMPANION_DOWNLOAD_DIR=
COMPANION_DISK_POLL_MS=5000
COMPANION_SCAN_POLL_MS=900000
COMPANION_HEARTBEAT_MS=15000
COMPANION_DELETE_POLL_MS=60000
COMPANION_DOWNLOAD_POLL_MS=60000
COMPANION_DOWNLOAD_STALL_MS=30000
COMPANION_MONITORED_TARGETS=[]
COMPANION_DISABLED_DISK_IDS=
PROTECTED_FOLDER_PIN=2468
# Comma-separated folder-name fragments protected by PIN, case-insensitive.
# Example: Private,Protected
PROTECTED_FOLDER_PATTERNS=Private,Protected
ADMIN_USER=admin
ADMIN_PASSWORD=replace-with-a-long-unique-password
THUMBNAILS_DIR=/data/video-catalog/thumbnails
PUBLIC_THUMBNAILS_BASE_URL=/thumbnails
